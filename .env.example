# MEF Portal - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ========== SUPABASE/PostgreSQL DATABASE CONFIGURATION ==========
# Get these values from your Supabase dashboard: https://supabase.com/dashboard
# 
# To find your credentials:
# 1. Go to Settings → Database
# 2. Copy connection string (URI) or individual credentials
# 3. Extract: Host, Port, Database, User, Password

# Supabase Connection Details (PostgreSQL)
DB_HOST=your-project.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-supabase-password-here
DB_NAME=postgres

# ========== FLASK CONFIGURATION ==========
# Secret key for session management (generate with: python -c "import secrets; print(secrets.token_hex(32))")
MEF_SECRET_KEY=your-secret-key-here-change-in-production

# Flask debug mode (set to False in production)
FLASK_DEBUG=False

# Server host and port
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ========== EMAIL CONFIGURATION (for future features) ==========
# For password reset and notifications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=noreply@mefportal.edu

# ========== SECURITY SETTINGS ==========
# Set to True in production (HTTPS only)
SESSION_COOKIE_SECURE=False

